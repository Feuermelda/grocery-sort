<Window x:Class="Grocery_Sort.CreateLayout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Grocery_Sort"
        mc:Ignorable="d"
        Title="CreateLayout" Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#d9dcff">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title Header -->
            <RowDefinition Height="*" />
            <!-- Layout Create Area -->
            <RowDefinition Height="Auto" />
            <!-- Save & Cancel Buttons -->
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#adb3f0" BorderThickness="2" CornerRadius="8" Margin="5"  Background="Lavender">
            <TextBlock x:Name="Layout" Text="Create Layout" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="10" Foreground="#222"/>
        </Border>

        <Border Grid.Row="1" BorderBrush="#adb3f0" BorderThickness="2" CornerRadius="8" Margin="5" Background="Lavender">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <!-- Enter Layout Name -->
                    <RowDefinition Height="*"/>
                    <!-- Category List -->
                    <RowDefinition Height="Auto" />
                    <!-- Add category button -->
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Enter Layout Name Area -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Layoutname" FontSize="13" Margin="5" Padding="5" VerticalAlignment="Center" Foreground="#222"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="EnterLayoutName" BorderThickness="1" Margin="5" Padding="5" VerticalAlignment="Center" Foreground="#222" Background="#f5f5ff"/>

                <!-- Category List Area -->
                <Border Grid.Row="1" Grid.ColumnSpan="3" BorderBrush="#adb3f0" BorderThickness="0,2,0,2" CornerRadius="0" Margin="5" Background="Lavender">
                    <ListBox ItemsSource="{Binding NewLayout.Categories}" x:Name="CategoryListBox" SelectionChanged="CategorySelected" BorderThickness="0" Margin="5" HorizontalContentAlignment="Stretch" Foreground="#222" Background="Lavender">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#7f5b87" CornerRadius="5" BorderThickness="1" Margin="5" Background="#f5f5ff">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.RowSpan="2" Grid.Column="0" Text="{Binding}" Padding="10" Margin="5" VerticalAlignment="Center"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,5,10,5">
                                            <Button Grid.Row="0" Content="Up" Click="Up_Click" Margin="0,0,10,3" Background="#adaded" Padding="0,5" Foreground="#222" />
                                            <Button Grid.Row="1" Content="Down" Click="Down_Click" Margin="0,3,10,0" Background="#adaded" Padding="0,5" Foreground="#222"/>
                                        </StackPanel>
                                        <Button Grid.Column="2" Content="X" Click="DeleteCategory_Click" Foreground="Red" FontWeight="Bold" Background="Transparent" Width="50" BorderThickness="0" Margin="0,5,10,5"/>
                                    </Grid>

                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Category" FontSize="13" Margin="5" Padding="5" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#222"/>

                <TextBox Grid.Row="2" Grid.Column="1" x:Name="EnterCategory" BorderThickness="1" Margin="5" Padding="5" VerticalAlignment="Center" Background="#f5f5ff" Foreground="#222"/>
                <Button Grid.Row="2" Grid.Column="2" Content="Add" x:Name="BtnAdd"  Click="AddCategory_Click" FontSize="13" VerticalAlignment="Center" Margin="10" Padding="10" Background="#adaded" Foreground="#222"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="Cancel" Click="Cancel_Click" Background="#adaded" FontSize="14" Margin="5" Padding="0,10" Foreground="#222"/>
            <Button Grid.Column="1" Content="Save" Click="Save_Click" Background="#adaded" FontSize="14" Margin="5" Padding="0,10" Foreground="#222"/>
        </Grid>
    </Grid>
</Window>
