<Window x:Class="Grocery_Sort.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Grocery_Sort"
        mc:Ignorable="d"
        Title="Grocery Sort" Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#effce3"
        Foreground="#222">
    <Grid Margin="10" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title Area -->
        <Border Grid.Row="0" BorderBrush="#ade002" BorderThickness="2" CornerRadius="8" Margin="0,0,0,10" Padding="15" Background="#f7fff0">
            <StackPanel VerticalAlignment="Center" >
                <TextBlock Text="Grocery Sort" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="Grocery Items sorted by custom Store Layout for a more efficient shopping trip." FontSize="12" HorizontalAlignment="Center" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Selected / Current List Area -->
        <Border Grid.Row="1" BorderBrush="#ade002" BorderThickness="2" CornerRadius="8" Margin="0,0,0,10" Padding="10" Background="#f7fff0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- list name and layout name -->
                    <TextBlock Grid.Column="0" Text="Current List" FontSize="20" FontWeight="Bold" Margin="5,0,0,5" VerticalAlignment="Center"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <TextBlock Text="{Binding CurrentList.Name}" FontSize="18" FontWeight="Bold" Margin="0,0,15,5" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding CurrentList.Layout.Name}" FontSize="18" FontWeight="Bold"  Margin="0,0,5,5" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Border Grid.Row="2" Padding="8" BorderBrush="#ade002" BorderThickness="0,2,0,0">
                    <ListBox ItemsSource="{Binding CurrentList.Items}" BorderThickness="0" HorizontalContentAlignment="Stretch" Background="#f7fff0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked}" Checked="ItemCheckedChanged" Unchecked="ItemCheckedChanged" VerticalAlignment="Center">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding Name}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                                <Setter Property="Foreground" Value="Gray"/>
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                            </TextBlock.Style>
                                            </TextBlock>

                                            <TextBlock Grid.Column="1">
                                                <Run Text=" ["/>                                                               
                                                <Run Text="{Binding ItemCategory}"/>
                                                <Run Text="]"/>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#222"/>

                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                                <Setter Property="Foreground" Value="Gray"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Grid.Column="2">
                                            <Run Text=" ("/>
                                                <Run Text="{Binding Amount}"/>
                                                <Run Text=")"/>
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#222"/>

                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                                <Setter Property="Foreground" Value="Gray"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </CheckBox>

                                    <Button Grid.Column="1" Content="X" BorderThickness ="0" Click="RemoveItem_Click"
                                        FontWeight="Bold" Foreground="Red" Background="Transparent"
                                        HorizontalAlignment="Right" Margin="0,0,5,0"/>

                                    <Button Grid.Column="2" Content="✏️" BorderThickness ="0" Click="EditItem_Click"
                                        FontWeight="Bold" Background="Transparent"
                                        HorizontalAlignment="Right" Margin="5,0,0,0"/>

                                    <Button Grid.Column="3" BorderThickness ="0" Click="Favorite_Click"
                                            FontWeight="Bold" Background="Transparent"
                                            HorizontalAlignment="Right" Margin="5,0,0,0">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Content" Value="🤍"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFavorite}" Value="true">
                                                        <Setter Property="Content" Value="❤️"/>
                                                        <Setter Property="Foreground" Value="PaleVioletRed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Button Grid.Row="3" Content="Add Item" Click="AddItem_Click" Margin="7,0,7,0" Padding="0,5"  FontSize="13" Background="#ade002" Foreground="#222"/>
            </Grid>
        </Border>

        <!-- Action Buttons -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="PaleGoldenrod" Background="#fcf6c2"  BorderThickness="1" CornerRadius="8" Margin="5,0,5,5">
                <Button Content="Create List" Click="CreateList_Click" FontSize="14" Background="Transparent" BorderThickness="0" Margin="5" Foreground="#222"/>
            </Border>

            <Border Grid.Column="1" BorderBrush="#c15acc" Background="#fa9df3" BorderThickness="1" CornerRadius="8" Margin="5,0,5,5">
                <Button Content="View Lists" Click="ViewLists_Click" FontSize="14" Background="Transparent" BorderThickness="0" Margin="5" Foreground="#222"/>
            </Border>

            <Border Grid.Column="2" BorderBrush="#395fbf" Background="#87a6f5" BorderThickness="1" CornerRadius="8" Margin="5,0,5,5">
                <Button Content="Manage Layouts" Click="ManageLayouts_Click" FontSize="14" Background="Transparent" BorderThickness="0" Margin="5" Foreground="#222"/>
            </Border>

        </Grid>
    </Grid>
</Window>
