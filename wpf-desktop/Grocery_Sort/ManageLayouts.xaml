<Window x:Class="Grocery_Sort.ManageLayouts"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Grocery_Sort"
        mc:Ignorable="d"
        Title="ManageLayouts" Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#d9f8fc">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title Header -->
            <RowDefinition Height="*"/>
            <!-- Layout List Area -->
            <RowDefinition Height="Auto"/>
            <!-- Action Buttons -->
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="CornflowerBlue" BorderThickness="2" CornerRadius="8" Margin="5"  Background="#e6f8fa">
            <TextBlock  Text="My Layouts" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="10" Foreground="#222"/>
        </Border>

        <Border Grid.Row="1" BorderBrush="CornflowerBlue" BorderThickness="2" CornerRadius="8" Margin="5" Background="#e6f8fa">
            <ListBox ItemsSource="{Binding AllLayouts}" x:Name="LayoutListBox" BorderThickness="0" Margin="5" HorizontalContentAlignment="Stretch" Background="#e6f8fa" Foreground="#222">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="CornflowerBlue" CornerRadius="5" BorderThickness="1" Margin="5" Background="#f7feff">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>


                                <TextBlock Grid.Column="0" Text="{Binding Name}" Padding="10" Margin="5" VerticalAlignment="Center" FontSize="13" Foreground="#222"/>


                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,10,10,10" >
                                    <Button Content="Edit Layout" Click="EditLayout_Click" Margin="0,0,5,0" Padding="10" Background="#95c9ed" Foreground="#222"/>
                                    <Button Content="Delete Layout" Click="DeleteLayout_Click" Margin="5,0,5,0" Padding="10" Background="#95c9ed" Foreground="#222"/>
                                </StackPanel>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="Back" Click="Back_Click" Margin="10,5" Padding="20" FontSize="16" Background="#95c9ed" Foreground="#222"/>
            <Button Grid.Column="1" Content="Create Layout" Click="Create_Click" Margin="10,5" Padding="20" FontSize="16" Background="#95c9ed" Foreground="#222"/>

        </Grid>
    </Grid>
</Window>
