<Window x:Class="Grocery_Sort.ViewLists"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Grocery_Sort"
        mc:Ignorable="d"
        Title="ViewLists" Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#fcebff">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" BorderBrush="#d496e3" BorderThickness="2" CornerRadius="8" Margin="5"  Background="#f9f5fa">
            <TextBlock  Text="My Lists" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="10" Foreground="#222"/>
        </Border>

        <Border Grid.Row="1" BorderBrush="#d496e3" BorderThickness="2" CornerRadius="8" Margin="5" Padding="5" Background="#f9f5fa">
            <Grid>
                <ListBox ItemsSource="{Binding GroceryLists}" HorizontalContentAlignment="Stretch" BorderThickness="0" Background="#f9f5fa">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#ec9cff" BorderThickness="1" CornerRadius="3" Padding="8" Margin="5" Background="#f9f5fa">

                                <Grid MaxHeight="200" HorizontalAlignment="Stretch">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="110"  />
                                        <!-- Row 0 - Listname Row 1 - item name-->
                                        <ColumnDefinition Width="100"  />
                                        <!-- Row 0 - Layoutname Row 1 - category -->
                                        <ColumnDefinition Width="*"/>
                                        <!--- Row 0 - spacer -->
                                        <ColumnDefinition Width="100"/>
                                        <!-- Row 0 - Buttons -->
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" TextWrapping="Wrap" Margin="0,10,0,0" VerticalAlignment="Center" Foreground="#222">
                                    <Run Text="{Binding Name}"/>
                                    </TextBlock>
                                    <TextBlock Grid.Row="0" Grid.Column="1" TextWrapping="Wrap" Margin="10,10,0,0" VerticalAlignment="Center" Foreground="#222" >
                                    <Run Text="["/>
                                    <Run Text="{Binding Layout.Name}" />
                                    <Run Text="]"/>
                                    </TextBlock>

                                    <StackPanel Grid.Row="0" Grid.RowSpan="3" Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,10,0,0" >
                                        <Button Content="Edit List" Click="EditList_Click" Margin="0,5,0,5" Padding="10" Background="#f5d7fa" Foreground="#222"/>
                                        <Button Content="Delete List" Click="DeleteList_Click" Margin="0,5,0,5" Padding="10" Background="#f5d7fa" Foreground="#222"/>
                                        <Button Content="Select Main" Click="SelectList_Click" Margin="0,5,0,5" Padding="10" Background="#f5d7fa" Foreground="#222"/>
                                    </StackPanel>

                                    <ItemsControl ItemsSource="{Binding Items}" Margin="0,8,0,0" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"  >
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2,0,2" HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="110" />
                                                        <ColumnDefinition Width="100" />
                                                        <ColumnDefinition Width="70"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="•  " Foreground="#222" TextWrapping="Wrap" />

                                                    <TextBlock Grid.Column="0" Text="{Binding Name}" TextWrapping="Wrap" Margin="10,0,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#222"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                                        <Setter Property="Foreground" Value="Gray"/>
                                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <TextBlock Grid.Column="1" Margin="10,0,0,0" TextWrapping="Wrap">
                                                    <Run Text="["/>
                                                    <Run Text="{Binding ItemCategory}"/>
                                                    <Run Text="]"/>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#222"/>

                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                                        <Setter Property="Foreground" Value="Gray"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <TextBlock Grid.Column="2" TextWrapping="Wrap">
                                                    <Run Text=" ("/>
                                                    <Run Text="{Binding Amount}"/>
                                                    <Run Text=")"/>
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#222"/>

                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                                        <Setter Property="Foreground" Value="Gray"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
        <Button Content="Back" Grid.Row="2" Click="Back_Click" Background="#f5d7fa" Margin="10,5" Padding="0,10" FontSize="14" Foreground="#222"/>
    </Grid>
</Window>
